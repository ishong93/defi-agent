# .env.example — 복사 후 .env로 저장하고 값 채우기

# 필수
ANTHROPIC_API_KEY=sk-ant-...

# 체인 RPC (기본값 있음, 필요 시 교체)
FLARE_RPC_URL=https://flare-api.flare.network/ext/C/rpc
XDC_RPC_URL=https://rpc.xinfin.network
XRPL_WS=wss://xrplcluster.com

# 선택 - 텔레그램 알림
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 선택 - Notion 리포트 저장
NOTION_API_KEY=
NOTION_DB_ID=
