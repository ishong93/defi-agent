# .env.example — 복사 후 .env로 저장하고 값 채우기

# 필수
ANTHROPIC_API_KEY=sk-ant-...

# 조회 대상 지갑 주소 (CLI --wallet-* 인자로 오버라이드 가능)
# 비워두면 해당 체인은 스냅샷 수집에서 제외된다.
WALLET_FLARE=
WALLET_XDC=
WALLET_XRPL=

# 체인 RPC (기본값 있음, 필요 시 교체)
FLARE_RPC_URL=https://flare-api.flare.network/ext/C/rpc
XDC_RPC_URL=https://rpc.xinfin.network
XRPL_WS=wss://xrplcluster.com

# 선택 - 텔레그램 알림
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 선택 - Notion 리포트 저장
NOTION_API_KEY=
NOTION_DB_ID=

# 선택 - CoinGecko (없으면 무료 플랜 사용, Pro 키 사용 시 요청 한도 증가)
COINGECKO_API_KEY=
